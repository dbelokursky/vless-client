<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vlessclient.ui.view.SubscriptionsViewController"
      spacing="16">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Subscriptions" styleClass="view-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="refreshAllButton" text="Refresh All" styleClass="secondary-button"
                onAction="#onRefreshAllClicked"/>
        <Button fx:id="addSubscriptionButton" text="+ Add Subscription" styleClass="primary-button"
                onAction="#onAddSubscriptionClicked"/>
    </HBox>

    <!-- Split: subscriptions on top, servers below -->
    <SplitPane orientation="VERTICAL" dividerPositions="0.5" VBox.vgrow="ALWAYS">

        <!-- Subscription List -->
        <VBox spacing="8">
            <ListView fx:id="subscriptionListView" styleClass="server-list" VBox.vgrow="ALWAYS"/>

            <!-- Empty state -->
            <VBox fx:id="emptyState" styleClass="empty-state" spacing="8" alignment="CENTER"
                  VBox.vgrow="ALWAYS" managed="true" visible="true">
                <Label text="&#x1F517;" styleClass="empty-state-icon"/>
                <Label text="No subscriptions" styleClass="empty-state-title"/>
                <Label text="Click 'Add Subscription' to import servers from a URL"
                       styleClass="empty-state-hint"/>
            </VBox>
        </VBox>

        <!-- Servers of selected subscription -->
        <VBox spacing="8">
            <Label fx:id="serversLabel" text="Servers" styleClass="section-title"/>
            <ListView fx:id="serverListView" styleClass="server-list" VBox.vgrow="ALWAYS"/>
        </VBox>

    </SplitPane>
</VBox>
