<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vlessclient.ui.view.RoutingViewController"
      spacing="16">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Routing" styleClass="view-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="downloadGeodataButton" text="Download Geodata" styleClass="secondary-button"
                onAction="#onDownloadGeodataClicked"/>
    </HBox>

    <!-- Preset selector -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Preset:" styleClass="section-title"/>
        <ComboBox fx:id="presetCombo" prefWidth="200"/>
    </HBox>

    <!-- Geodata status -->
    <Label fx:id="geodataStatusLabel" text="" styleClass="server-address"/>

    <!-- Bypass list: patterns matching these are sent direct, skipping the proxy -->
    <VBox spacing="6" styleClass="card">
        <padding>
            <Insets top="14" right="16" bottom="14" left="16"/>
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Bypass list" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="saveBypassButton" text="Save" styleClass="primary-button"
                    onAction="#onSaveBypassClicked"/>
        </HBox>
        <Label styleClass="server-address" wrapText="true"
               text="One entry per line. These hosts go direct and bypass the VPN. Supports wildcards: *.example.com, .example.com, *google*, CIDR (192.168.0.0/16), bare IPs, URLs. Lines starting with # are comments."/>
        <TextArea fx:id="bypassListArea" prefRowCount="6" wrapText="false"
                  promptText="*.github.com&#10;api.openai.com&#10;192.168.0.0/16&#10;# legacy in-house services&#10;.corp.local"/>
    </VBox>

    <!-- Custom rules section (visible only when preset is Custom) -->
    <VBox fx:id="customRulesSection" spacing="8" VBox.vgrow="ALWAYS" managed="false" visible="false">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Custom Rules" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="addRuleButton" text="+ Add Rule" styleClass="primary-button"
                    onAction="#onAddRuleClicked"/>
        </HBox>

        <ListView fx:id="rulesListView" styleClass="server-list" VBox.vgrow="ALWAYS"/>

        <!-- Empty state -->
        <VBox fx:id="emptyState" styleClass="empty-state" spacing="8" alignment="CENTER"
              VBox.vgrow="ALWAYS" managed="true" visible="true">
            <Label text="No custom rules" styleClass="empty-state-title"/>
            <Label text="Click 'Add Rule' to create routing rules"
                   styleClass="empty-state-hint"/>
        </VBox>
    </VBox>
</VBox>
