<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vlessclient.ui.view.RoutingViewController"
      spacing="16">

    <!-- Header -->
    <Label text="Routing" styleClass="view-title"/>

    <!-- Routing mode card: preset + (optional) bypass country, aligned in a
         single label column so the controls line up. -->
    <VBox styleClass="card" spacing="12">
        <padding>
            <Insets top="16" right="18" bottom="16" left="18"/>
        </padding>

        <Label text="Routing mode" styleClass="section-title"/>

        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Preset" styleClass="field-label" minWidth="130" prefWidth="130"/>
            <ComboBox fx:id="presetCombo" prefWidth="220"/>
        </HBox>

        <!-- Bypass countries: shown only for the Bypass Domestic preset.
             Selected codes render as removable chips (added by the controller
             in front of the combo); the combo stays editable so power users
             can type ISO codes beyond the common list. -->
        <HBox fx:id="bypassCountryRow" alignment="CENTER_LEFT" spacing="12"
              managed="false" visible="false">
            <Label text="Bypass countries" styleClass="field-label" minWidth="130" prefWidth="130"/>
            <FlowPane fx:id="bypassCountryChips" hgap="6" vgap="6"
                      alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <ComboBox fx:id="bypassCountryCombo" prefWidth="110" editable="true"
                          promptText="add..."/>
            </FlowPane>
        </HBox>

        <Label fx:id="bypassCountryHint" styleClass="hint-label" wrapText="true"
               managed="false" visible="false"
               text="Geosite/geoip rules for these countries and the private LAN go direct; everything else is routed through the VPN. Countries without a sing-geosite aggregate (most, apart from ru/cn/ir) match by IP ranges only."/>
    </VBox>

    <!-- Bypass list: patterns matching these are sent direct, skipping the proxy -->
    <VBox spacing="8" styleClass="card" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="14" right="16" bottom="16" left="16"/>
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Bypass list" styleClass="section-title"/>
            <Label fx:id="bypassCountLabel" text="0 entries" styleClass="count-badge"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="saveBypassButton" text="Save" styleClass="primary-button"
                    onAction="#onSaveBypassClicked"/>
        </HBox>
        <Label styleClass="hint-label" wrapText="true"
               text="One entry per line — these hosts go direct and bypass the VPN. Wildcards: *.example.com, .example.com, *google*; CIDR (192.168.0.0/16); bare IPs; URLs. Lines starting with # are comments."/>
        <TextArea fx:id="bypassListArea" styleClass="code-area" prefRowCount="8"
                  wrapText="false" VBox.vgrow="ALWAYS"
                  promptText="*.github.com&#10;api.openai.com&#10;192.168.0.0/16&#10;# legacy in-house services&#10;.corp.local"/>
    </VBox>

    <!-- Custom rules section (visible only when preset is Custom) -->
    <VBox fx:id="customRulesSection" spacing="8" styleClass="card" VBox.vgrow="ALWAYS"
          managed="false" visible="false">
        <padding>
            <Insets top="14" right="16" bottom="16" left="16"/>
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Custom rules" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="addRuleButton" text="+ Add Rule" styleClass="primary-button"
                    onAction="#onAddRuleClicked"/>
        </HBox>

        <ListView fx:id="rulesListView" styleClass="server-list" VBox.vgrow="ALWAYS"/>

        <!-- Empty state -->
        <VBox fx:id="emptyState" styleClass="empty-state" spacing="8" alignment="CENTER"
              VBox.vgrow="ALWAYS" managed="true" visible="true">
            <Label text="No custom rules" styleClass="empty-state-title"/>
            <Label text="Click 'Add Rule' to create routing rules"
                   styleClass="empty-state-hint"/>
        </VBox>
    </VBox>
</VBox>
