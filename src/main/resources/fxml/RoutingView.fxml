<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vlessclient.ui.view.RoutingViewController"
      spacing="16">

    <!-- Header -->
    <Label text="Routing" styleClass="view-title"/>

    <!-- Bypass countries: selected codes render as removable chips (added by
         the controller in front of the combo). The combo lists every ISO
         country as "code — name" and stays editable; committed input is
         validated against the ISO catalog, so a typo can never become a
         broken rule-set URL. Empty selection = no country bypass. -->
    <VBox styleClass="card" spacing="8">
        <padding>
            <Insets top="16" right="18" bottom="16" left="18"/>
        </padding>

        <Label text="Bypass countries" styleClass="section-title"/>

        <FlowPane fx:id="bypassCountryChips" hgap="6" vgap="6"
                  alignment="CENTER_LEFT">
            <ComboBox fx:id="bypassCountryCombo" prefWidth="200" editable="true"
                      promptText="add country..."/>
        </FlowPane>

        <Label fx:id="bypassCountryHint" styleClass="hint-label" wrapText="true"
               text="Traffic of these countries goes direct, past the VPN; empty means everything is routed through the VPN. Countries without a sing-geosite aggregate (most, apart from ru/cn/ir) match by IP ranges only."/>
    </VBox>

    <!-- Bypass list: patterns matching these are sent direct, skipping the proxy -->
    <VBox spacing="8" styleClass="card" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="14" right="16" bottom="16" left="16"/>
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Bypass list" styleClass="section-title"/>
            <Label fx:id="bypassCountLabel" text="0 entries" styleClass="count-badge"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="saveBypassButton" text="Save" styleClass="primary-button"
                    onAction="#onSaveBypassClicked"/>
        </HBox>
        <Label styleClass="hint-label" wrapText="true"
               text="One entry per line — these hosts go direct and bypass the VPN. Wildcards: *.example.com, .example.com, *google*; CIDR (192.168.0.0/16); bare IPs; URLs. Lines starting with # are comments."/>
        <TextArea fx:id="bypassListArea" styleClass="code-area" prefRowCount="8"
                  wrapText="false" VBox.vgrow="ALWAYS"
                  promptText="*.github.com&#10;api.openai.com&#10;192.168.0.0/16&#10;# legacy in-house services&#10;.corp.local"/>
    </VBox>

    <!-- Custom rules: always active, composing with the sections above -->
    <VBox fx:id="customRulesSection" spacing="8" styleClass="card" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="14" right="16" bottom="16" left="16"/>
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Custom rules" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="addRuleButton" text="+ Add Rule" styleClass="primary-button"
                    onAction="#onAddRuleClicked"/>
        </HBox>

        <ListView fx:id="rulesListView" styleClass="server-list" VBox.vgrow="ALWAYS"/>

        <!-- Empty state -->
        <VBox fx:id="emptyState" styleClass="empty-state" spacing="8" alignment="CENTER"
              VBox.vgrow="ALWAYS" managed="true" visible="true">
            <Label text="No custom rules" styleClass="empty-state-title"/>
            <Label text="Click 'Add Rule' to create routing rules"
                   styleClass="empty-state-hint"/>
        </VBox>
    </VBox>
</VBox>
