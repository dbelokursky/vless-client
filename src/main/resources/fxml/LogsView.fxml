<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Priority?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vlessclient.ui.view.LogsViewController"
      spacing="12">

    <!-- Header -->
    <Label text="Logs" styleClass="view-title"/>

    <!-- Toolbar. The search field is the single elastic element (HBox.hgrow);
         every other control keeps its preferred size (minWidth=-Infinity =
         USE_PREF_SIZE) so labels never get squeezed/truncated on a narrow
         window — only the search field shrinks, down to its minWidth. -->
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="logs-toolbar">
        <padding>
            <Insets top="4" bottom="4"/>
        </padding>

        <ComboBox fx:id="logLevelFilter" prefWidth="110" minWidth="-Infinity"
                  styleClass="combo-box"/>

        <TextField fx:id="searchField" promptText="Search logs..." minWidth="90"
                   HBox.hgrow="ALWAYS" styleClass="form-field"/>

        <CheckBox fx:id="autoScrollCheckBox" text="Auto-scroll" selected="true"
                  minWidth="-Infinity" styleClass="form-checkbox"/>

        <Button fx:id="downloadButton" styleClass="icon-button" minWidth="-Infinity"
                onAction="#onDownloadClicked"/>

        <Button fx:id="clearButton" styleClass="icon-button" minWidth="-Infinity"
                onAction="#onClearClicked"/>
    </HBox>

    <!-- Log Lines -->
    <ListView fx:id="logListView" styleClass="log-list-view" VBox.vgrow="ALWAYS"/>
</VBox>
