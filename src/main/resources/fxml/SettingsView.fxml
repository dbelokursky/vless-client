<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.control.ScrollPane?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.vlessclient.ui.view.SettingsViewController"
            fitToWidth="true" styleClass="form-scroll">
    <VBox spacing="20" styleClass="form-content">
        <padding>
            <Insets top="8" right="16" bottom="24" left="16"/>
        </padding>

        <!-- Title -->
        <Label fx:id="titleLabel" text="Settings" styleClass="view-title"/>

        <!-- Appearance Section -->
        <VBox spacing="12" styleClass="card">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>

            <Label fx:id="appearanceLabel" text="Appearance" styleClass="form-section-title"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="themeLabel" text="Theme" styleClass="form-label" prefWidth="120"/>
                <ComboBox fx:id="themeCombo" styleClass="form-field" prefWidth="200"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="languageLabel" text="Language" styleClass="form-label" prefWidth="120"/>
                <ComboBox fx:id="languageCombo" styleClass="form-field" prefWidth="200"/>
            </HBox>
        </VBox>

        <!-- Connection Section -->
        <VBox spacing="12" styleClass="card">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>

            <Label fx:id="connectionLabel" text="Connection" styleClass="form-section-title"/>

            <CheckBox fx:id="autoConnectCheck" text="Auto-connect on startup" styleClass="form-checkbox"/>

            <CheckBox fx:id="launchAtLoginCheck" text="Launch at login" styleClass="form-checkbox"/>

            <Separator styleClass="sidebar-separator"/>

            <Label fx:id="proxyPortsLabel" text="Proxy Ports" styleClass="form-label"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="socksPortLabel" text="SOCKS Port" styleClass="form-label" prefWidth="120"/>
                <TextField fx:id="socksPortField" styleClass="form-field" prefWidth="120"
                           promptText="1080"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="httpPortLabel" text="HTTP Port" styleClass="form-label" prefWidth="120"/>
                <TextField fx:id="httpPortField" styleClass="form-field" prefWidth="120"
                           promptText="1081"/>
            </HBox>

            <Separator styleClass="sidebar-separator"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="proxyModeLabel" text="Proxy Mode" styleClass="form-label" prefWidth="120"/>
                <ComboBox fx:id="proxyModeCombo" styleClass="form-field" prefWidth="200"/>
            </HBox>

            <CheckBox fx:id="systemProxyAutoConfigCheck" text="Set system proxy automatically"
                      styleClass="form-checkbox"/>
        </VBox>

        <!-- Health Check Section -->
        <VBox spacing="12" styleClass="card">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>

            <Label fx:id="healthCheckLabel" text="Health Check" styleClass="form-section-title"/>

            <CheckBox fx:id="healthCheckEnabledCheck" text="Enable health check"
                      styleClass="form-checkbox"/>

            <CheckBox fx:id="healthCheckAutoReconnectCheck" text="Auto-reconnect when unreachable"
                      styleClass="form-checkbox"/>

            <Separator styleClass="sidebar-separator"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="healthCheckIntervalLabel" text="Check interval (sec)"
                       styleClass="form-label" prefWidth="200"/>
                <TextField fx:id="healthCheckIntervalField" styleClass="form-field" prefWidth="120"
                           promptText="5"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="healthCheckReconnectDelayLabel" text="Reconnect delay (sec)"
                       styleClass="form-label" prefWidth="200"/>
                <TextField fx:id="healthCheckReconnectDelayField" styleClass="form-field" prefWidth="120"
                           promptText="10"/>
            </HBox>
        </VBox>

        <!-- Advanced Section -->
        <VBox spacing="12" styleClass="card">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>

            <Label fx:id="advancedLabel" text="Advanced" styleClass="form-section-title"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="proxyDnsLabel" text="Proxy DNS" styleClass="form-label" prefWidth="160"/>
                <TextField fx:id="proxyDnsField" styleClass="form-field" prefWidth="280"
                           promptText="https://1.1.1.1/dns-query"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="directDnsLabel" text="Direct DNS" styleClass="form-label" prefWidth="160"/>
                <TextField fx:id="directDnsField" styleClass="form-field" prefWidth="280"
                           promptText="https://223.5.5.5/dns-query"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="tunInterfaceNameLabel" text="TUN Interface Name"
                       styleClass="form-label" prefWidth="160"/>
                <TextField fx:id="tunInterfaceNameField" styleClass="form-field" prefWidth="200"
                           promptText="utun99"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="tunIpv4Label" text="TUN IPv4 Address"
                       styleClass="form-label" prefWidth="160"/>
                <TextField fx:id="tunIpv4Field" styleClass="form-field" prefWidth="200"
                           promptText="172.19.0.1/30"/>
            </HBox>

            <CheckBox fx:id="storeSecretsCheck" text="Store credentials in the system keychain"
                      styleClass="form-checkbox"/>
        </VBox>

        <!-- About Section -->
        <VBox spacing="8" styleClass="card">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>

            <Label fx:id="aboutLabel" text="About" styleClass="form-section-title"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="appVersionLabel" text="App Version" styleClass="form-label" prefWidth="120"/>
                <Label fx:id="appVersionValue" text="1.0.0" styleClass="stats-value"
                       style="-fx-font-size: 13px;"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="singboxVersionLabel" text="sing-box Version" styleClass="form-label"
                       prefWidth="120"/>
                <Label fx:id="singboxVersionValue" text="Unknown" styleClass="stats-value"
                       style="-fx-font-size: 13px;"/>
            </HBox>

            <!-- Updates: the app and the sing-box core, each on its own row
                 with a status dot, current→latest detail, and an action.
                 One "Check for updates" checks both. -->
            <VBox styleClass="updates-section" spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="updatesLabel" text="Updates" styleClass="section-header"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="checkCoreUpdateButton" text="Check for updates"/>
                </HBox>

                <ProgressBar fx:id="coreUpdateProgress" visible="false" managed="false"
                             maxWidth="Infinity" prefHeight="14"/>

                <!-- App sub-block: name + action on top, status below -->
                <VBox fx:id="appUpdateRow" styleClass="update-item" spacing="3">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle fx:id="appUpdateDot" radius="5"
                                styleClass="status-circle-disconnected"/>
                        <Label fx:id="appUpdateNameLabel" text="App" styleClass="service-name"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="downloadAppButton" text="Download" visible="false"
                                managed="false"/>
                    </HBox>
                    <Label fx:id="appUpdateDetail" text="" styleClass="core-status"/>
                </VBox>

                <!-- sing-box core sub-block -->
                <VBox fx:id="coreUpdateRow" styleClass="update-item" spacing="3">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle fx:id="coreUpdateDot" radius="5"
                                styleClass="status-circle-disconnected"/>
                        <Label fx:id="coreUpdateNameLabel" text="sing-box"
                               styleClass="service-name"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="installCoreUpdateButton" text="Update" visible="false"
                                managed="false"/>
                        <Button fx:id="rollbackCoreButton" text="Roll back" visible="false"
                                managed="false"/>
                    </HBox>
                    <Label fx:id="coreUpdateStatusLabel" text="" styleClass="core-status"/>
                </VBox>
            </VBox>
        </VBox>

    </VBox>
</ScrollPane>
