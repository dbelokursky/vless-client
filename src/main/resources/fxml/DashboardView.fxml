<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vlessclient.ui.view.DashboardViewController"
      spacing="20" alignment="TOP_CENTER">

    <!-- Sing-box missing banner (hidden when engine is available) -->
    <HBox fx:id="singBoxMissingBanner" styleClass="singbox-missing-banner"
          spacing="12" alignment="CENTER_LEFT"
          visible="false" managed="false">
        <padding>
            <Insets top="12" right="16" bottom="12" left="16"/>
        </padding>
        <Label text="&#x26A0;" styleClass="banner-icon"/>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="sing-box is not installed" styleClass="banner-title"/>
            <Label text="Install it with Homebrew, then restart the app:" styleClass="banner-subtitle"/>
            <Label fx:id="brewCommandLabel" text="brew install sing-box" styleClass="banner-command"/>
        </VBox>
        <Button fx:id="copyBrewButton" text="Copy" styleClass="secondary-button"
                onAction="#onCopyBrewCommandClicked"/>
        <Button fx:id="retryInstallButton" text="Retry download" styleClass="secondary-button"
                onAction="#onRetryInstallClicked"/>
    </HBox>

    <!-- Connection Status Card -->
    <VBox styleClass="card, hero-card" spacing="18" alignment="CENTER">
        <padding>
            <Insets top="36" right="40" bottom="32" left="40"/>
        </padding>

        <!-- Big halo around the status circle -->
        <StackPane fx:id="statusHalo" styleClass="status-halo"
                   prefWidth="72" prefHeight="72" maxWidth="72" maxHeight="72">
            <Circle fx:id="statusCircle" radius="16" styleClass="status-circle-disconnected"/>
        </StackPane>

        <Label fx:id="statusTitle" text="Disconnected" styleClass="status-title"/>

        <Label fx:id="statusLabel" text="Not connected to any server" styleClass="status-subtitle"
               wrapText="true" maxWidth="560" alignment="CENTER" textAlignment="CENTER"/>

        <Label fx:id="serverNameLabel" text="" styleClass="server-name-label"
               managed="false" visible="false"/>

        <HBox alignment="CENTER" spacing="10">
            <Label text="Mode" styleClass="stats-title"/>
            <ComboBox fx:id="proxyModeCombo" prefWidth="150" styleClass="mode-combo"/>
        </HBox>

        <Label fx:id="proxyModeWarning" text="" styleClass="hint-label"
               visible="false" managed="false"/>

        <Button fx:id="connectButton" text="Connect" styleClass="connect-button"
                onAction="#onConnectClicked" prefWidth="220" prefHeight="48">
        </Button>
    </VBox>

    <!-- Speed Stats Grid -->
    <GridPane hgap="16" vgap="16">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
        </columnConstraints>

        <!-- Upload Speed -->
        <VBox styleClass="card, stats-card, upload-card" spacing="4" alignment="CENTER_LEFT"
              GridPane.columnIndex="0" GridPane.rowIndex="0">
            <padding>
                <Insets top="18" right="20" bottom="18" left="22"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="&#x2B06;" styleClass="stats-icon-upload"/>
                <Label text="Upload" styleClass="stats-title"/>
            </HBox>
            <Label fx:id="uploadSpeedLabel" text="—" styleClass="speed-value"/>
        </VBox>

        <!-- Download Speed -->
        <VBox styleClass="card, stats-card, download-card" spacing="4" alignment="CENTER_LEFT"
              GridPane.columnIndex="1" GridPane.rowIndex="0">
            <padding>
                <Insets top="18" right="20" bottom="18" left="22"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="&#x2B07;" styleClass="stats-icon-download"/>
                <Label text="Download" styleClass="stats-title"/>
            </HBox>
            <Label fx:id="downloadSpeedLabel" text="—" styleClass="speed-value"/>
        </VBox>

        <!-- Total Uploaded -->
        <VBox styleClass="card, stats-card-small" spacing="4" alignment="CENTER_LEFT"
              GridPane.columnIndex="0" GridPane.rowIndex="1">
            <padding>
                <Insets top="14" right="18" bottom="14" left="22"/>
            </padding>
            <Label text="Total Up" styleClass="stats-title"/>
            <Label fx:id="totalUploadLabel" text="—" styleClass="stats-value"/>
        </VBox>

        <!-- Total Downloaded -->
        <VBox styleClass="card, stats-card-small" spacing="4" alignment="CENTER_LEFT"
              GridPane.columnIndex="1" GridPane.rowIndex="1">
            <padding>
                <Insets top="14" right="18" bottom="14" left="22"/>
            </padding>
            <Label text="Total Down" styleClass="stats-title"/>
            <Label fx:id="totalDownloadLabel" text="—" styleClass="stats-value"/>
        </VBox>
    </GridPane>

    <!-- Latency Test -->
    <HBox alignment="CENTER" spacing="16">
        <Button fx:id="testLatencyButton" text="Test Latency" styleClass="secondary-button"
                onAction="#onTestLatencyClicked" prefHeight="36"/>
        <Label fx:id="latencyResultLabel" text="" styleClass="latency-result"/>
    </HBox>
</VBox>
