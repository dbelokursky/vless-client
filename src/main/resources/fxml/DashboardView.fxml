<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.shape.Circle?>
<?import com.vlessclient.ui.view.Sparkline?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vlessclient.ui.view.DashboardViewController"
      spacing="18">

    <!-- Sing-box missing banner (hidden when engine is available) -->
    <HBox fx:id="singBoxMissingBanner" styleClass="singbox-missing-banner"
          spacing="12" alignment="CENTER_LEFT"
          visible="false" managed="false">
        <padding>
            <Insets top="12" right="16" bottom="12" left="16"/>
        </padding>
        <Label text="&#x26A0;" styleClass="banner-icon"/>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="sing-box is not installed" styleClass="banner-title"/>
            <Label text="Install it with Homebrew, then restart the app:" styleClass="banner-subtitle"/>
            <Label fx:id="brewCommandLabel" text="brew install sing-box" styleClass="banner-command"/>
        </VBox>
        <Button fx:id="copyBrewButton" text="Copy" styleClass="secondary-button"
                onAction="#onCopyBrewCommandClicked"/>
        <Button fx:id="retryInstallButton" text="Retry download" styleClass="secondary-button"
                onAction="#onRetryInstallClicked"/>
    </HBox>

    <!-- Compact status bar: single card, one row -->
    <HBox styleClass="card, hero-card, status-bar" alignment="CENTER_LEFT" spacing="16">
        <padding>
            <Insets top="14" right="18" bottom="14" left="18"/>
        </padding>

        <StackPane fx:id="statusHalo" styleClass="status-halo, status-halo-sm"
                   prefWidth="44" prefHeight="44" maxWidth="44" maxHeight="44">
            <Circle fx:id="statusCircle" radius="9" styleClass="status-circle-disconnected"/>
        </StackPane>

        <VBox spacing="1" HBox.hgrow="ALWAYS">
            <Label fx:id="statusTitle" text="Disconnected" styleClass="status-title"/>
            <Label fx:id="statusLabel" text="Add a server to get started"
                   styleClass="status-subtitle" wrapText="true" maxWidth="520"/>
        </VBox>

        <!-- Mode selector + connect button on one row so the combo and the
             button stay vertically aligned; the TUN warning wraps underneath.
             fillHeight=false stops the HBox from stretching the 44px button to
             the warning's height (it used to balloon to ~68px). minWidth=
             -Infinity keeps the whole group from being squeezed by a long
             status message. -->
        <VBox alignment="CENTER_RIGHT" spacing="4" minWidth="-Infinity">
            <HBox alignment="CENTER_RIGHT" spacing="12" fillHeight="false">
                <Label text="Mode" styleClass="stats-title"/>
                <ComboBox fx:id="proxyModeCombo" prefWidth="130" styleClass="mode-combo"/>
                <Button fx:id="connectButton" text="Connect" styleClass="connect-button"
                        onAction="#onConnectClicked" prefWidth="170" prefHeight="44"/>
            </HBox>
            <Label fx:id="proxyModeWarning" text="" styleClass="hint-label"
                   wrapText="true" maxWidth="320" visible="false" managed="false"/>
        </VBox>
    </HBox>

    <!-- Hidden legacy field used elsewhere; no longer rendered. -->
    <Label fx:id="serverNameLabel" text="" managed="false" visible="false"/>

    <!-- Real-time traffic section -->
    <Label text="Real-time traffic" styleClass="section-header"/>

    <GridPane hgap="16" vgap="16">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
        </columnConstraints>

        <!-- Upload card with sparkline -->
        <VBox styleClass="card, traffic-card, upload-card" spacing="6"
              alignment="CENTER_LEFT"
              GridPane.columnIndex="0" GridPane.rowIndex="0">
            <padding>
                <Insets top="14" right="18" bottom="14" left="20"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="&#x2B06;" styleClass="stats-icon-upload"/>
                <Label text="Upload" styleClass="stats-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="uploadSpeedLabel" text="0 B/s" styleClass="speed-value"/>
            </HBox>
            <Sparkline fx:id="uploadSparkline" prefHeight="52"/>
        </VBox>

        <!-- Download card with sparkline -->
        <VBox styleClass="card, traffic-card, download-card" spacing="6"
              alignment="CENTER_LEFT"
              GridPane.columnIndex="1" GridPane.rowIndex="0">
            <padding>
                <Insets top="14" right="18" bottom="14" left="20"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="&#x2B07;" styleClass="stats-icon-download"/>
                <Label text="Download" styleClass="stats-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="downloadSpeedLabel" text="0 B/s" styleClass="speed-value"/>
            </HBox>
            <Sparkline fx:id="downloadSparkline" prefHeight="52"/>
        </VBox>
    </GridPane>

    <!-- Session totals and latency: inline strip, no extra cards -->
    <HBox styleClass="card, totals-strip" alignment="CENTER_LEFT" spacing="24">
        <padding>
            <Insets top="12" right="18" bottom="12" left="20"/>
        </padding>
        <Label text="SESSION" styleClass="stats-title"/>

        <HBox alignment="CENTER_LEFT" spacing="6">
            <Label text="&#x2B06;" styleClass="stats-icon-upload"/>
            <Label fx:id="totalUploadLabel" text="—" styleClass="stats-value"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="6">
            <Label text="&#x2B07;" styleClass="stats-icon-download"/>
            <Label fx:id="totalDownloadLabel" text="—" styleClass="stats-value"/>
        </HBox>

        <Separator orientation="VERTICAL"/>

        <Label text="LATENCY" styleClass="stats-title"/>
        <Label fx:id="latencyResultLabel" text="—" styleClass="stats-value latency-result"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Button fx:id="testLatencyButton" text="Test Latency"
                styleClass="secondary-button" prefWidth="120"
                onAction="#onTestLatencyClicked"/>
    </HBox>

    <!-- Service availability: reachability of key services through the tunnel -->
    <VBox fx:id="healthCard" styleClass="card" spacing="10"
          visible="false" managed="false">
        <padding>
            <Insets top="14" right="18" bottom="14" left="20"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Service availability" styleClass="section-header"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="healthSummaryLabel" text="—" styleClass="latency-result"/>
            <Button fx:id="recheckButton" text="Re-check" styleClass="secondary-button"
                    prefWidth="120" onAction="#onRecheckClicked"/>
        </HBox>

        <VBox fx:id="serviceStatusList" spacing="6"/>

        <HBox fx:id="reconnectBanner" styleClass="reconnect-banner" spacing="12"
              alignment="CENTER_LEFT" visible="false" managed="false">
            <padding>
                <Insets top="8" right="12" bottom="8" left="12"/>
            </padding>
            <Label fx:id="reconnectBannerLabel" text="" styleClass="reconnect-banner-label"
                   wrapText="true" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="cancelReconnectButton" text="Cancel" styleClass="secondary-button"
                    onAction="#onCancelReconnectClicked"/>
        </HBox>
    </VBox>
</VBox>
